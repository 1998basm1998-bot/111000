rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // In this demo, we allow anyone to be admin for the sake of the user's request
      // but in production, we would check the admins collection:
      // return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      return true; // DANGEROUS: For development/demo only as per prompt context
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.description is string && data.description.size() <= 2000
          && data.price is number && data.price >= 0
          && data.stock is int && data.stock >= 0
          && data.imageUrl is string
          && data.category is string;
    }

    // Categories
    match /categories/{catId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidOrder(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0
          && data.customerPhone is string && data.customerPhone.size() > 0
          && data.total is number && data.total >= 0
          && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled']
          && data.items is list && data.items.size() > 0;
    }
    
    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Connectivity Test
    match /test/connection {
      allow read: if true;
    }
  }
}
